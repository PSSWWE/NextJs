generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(255)
  email      String    @unique(map: "email") @db.VarChar(255)
  password   String    @db.VarChar(255)
  createdAt  DateTime? @default(now()) @db.DateTime(0)
  approvedAt DateTime? @db.DateTime(0)
  approvedBy Int?
  isApproved Boolean?  @default(false)
  role       String?   @default("USER") @db.VarChar(50)
  status     String?   @default("PENDING") @db.VarChar(50)
}

model Shipment {
  id                    Int       @id @default(autoincrement())
  trackingId            String?   @unique(map: "Shipment_trackingId_key") @db.VarChar(255)
  invoiceNumber         String?   @unique(map: "Shipment_invoiceNumber_key") @db.VarChar(255)
  referenceNumber       String?   @db.VarChar(255)
  agency                String?   @db.VarChar(255)
  office                String?   @db.VarChar(255)
  senderName            String?   @db.VarChar(255)
  senderAddress         String?   @db.Text
  recipientName         String?   @db.VarChar(255)
  recipientAddress      String?   @db.Text
  destination           String?   @db.VarChar(255)
  deliveryTime          String?   @db.VarChar(255)
  invoiceStatus         String?   @db.VarChar(255)
  deliveryStatus        String?   @db.VarChar(255)
  trackingStatus        String?   @db.VarChar(255)
  trackingStatusHistory String?   @db.LongText
  shippingMode          String?   @db.VarChar(255)
  packaging             String?   @db.VarChar(255)
  vendor                String?   @db.VarChar(255)
  serviceMode           String?   @db.VarChar(255)
  amount                Int?      @default(1)
  packageDescription    String?   @db.Text
  weight                Float?    @default(0)
  length                Float?    @default(0)
  width                 Float?    @default(0)
  height                Float?    @default(0)
  weightVol             Float?    @default(0)
  fixedCharge           Decimal?  @default(0.00) @db.Decimal(15, 2)
  decValue              Decimal?  @default(0.00) @db.Decimal(15, 2)
  price                 Decimal?  @default(0.00) @db.Decimal(15, 2)
  discount              Decimal?  @default(0.00) @db.Decimal(15, 2)
  fuelSurcharge         Decimal?  @default(0.00) @db.Decimal(15, 2)
  insurance             Decimal?  @default(0.00) @db.Decimal(15, 2)
  customs               Decimal?  @default(0.00) @db.Decimal(15, 2)
  tax                   Decimal?  @default(0.00) @db.Decimal(15, 2)
  declaredValue         Decimal?  @default(0.00) @db.Decimal(15, 2)
  reissue               Decimal?  @default(0.00) @db.Decimal(15, 2)
  profitPercentage      Float?    @default(0)
  cos                   Decimal?  @default(0.00) @db.Decimal(15, 2)
  totalCost             Decimal?  @db.Decimal(15, 2)
  subtotal              Decimal?  @default(0.00) @db.Decimal(15, 2)
  manualRate            Boolean?  @default(false)
  totalPackages         Int?      @default(0)
  totalWeight           Float?    @default(0)
  totalWeightVol        Float?    @default(0)
  shipmentDate          DateTime? @db.DateTime(0)
  packages              String?   @db.LongText
  packageTotals         String?   @db.LongText
  calculatedValues      String?   @db.LongText
  createdAt             DateTime? @default(now()) @db.DateTime(0)
  invoices              Invoice[]
}

model Customers {
  id             Int                   @id @default(autoincrement())
  CompanyName    String                @unique(map: "CompanyName") @db.VarChar(255)
  PersonName     String                @db.VarChar(255)
  Email          String                @db.VarChar(255)
  Phone          String                @db.VarChar(255)
  DocumentType   String                @db.VarChar(255)
  DocumentNumber String                @db.VarChar(255)
  Country        String                @db.VarChar(255)
  State          String                @db.VarChar(255)
  City           String                @db.VarChar(255)
  Zip            String                @db.VarChar(255)
  Address        String                @db.Text
  ActiveStatus   String                @db.VarChar(255)
  FilePath       String                @db.Text
  createdAt      DateTime?             @default(now()) @db.DateTime(0)
  currentBalance Decimal?              @default(0.00) @db.Decimal(15, 2)
  creditLimit    Decimal?              @default(0.00) @db.Decimal(15, 2)
  DocumentExpiry String?               @db.VarChar(255)
  invoices       Invoice[]
  transactions   CustomerTransaction[]
  creditNotes    CreditNote[]
}

model Vendors {
  id             Int                 @id @default(autoincrement())
  CompanyName    String              @unique(map: "CompanyName") @db.VarChar(255)
  PersonName     String              @db.VarChar(255)
  Email          String              @db.VarChar(255)
  Phone          String              @db.VarChar(255)
  Country        String              @db.VarChar(255)
  State          String              @db.VarChar(255)
  City           String              @db.VarChar(255)
  Zip            String              @db.VarChar(255)
  Address        String              @db.Text
  createdAt      DateTime?           @default(now()) @db.DateTime(0)
  currentBalance Decimal?            @default(0.00) @db.Decimal(15, 2)
  creditLimit    Decimal?            @default(0.00) @db.Decimal(15, 2)
  invoices       Invoice[]
  transactions   VendorTransaction[]
  debitNotes     DebitNote[]
}

model Recipients {
  id                  Int       @id @default(autoincrement())
  CompanyName         String?   @unique(map: "Recipients_CompanyName_key") @db.VarChar(255)
  PersonName          String?   @db.VarChar(255)
  Email               String?   @db.VarChar(255)
  Phone               String?   @db.VarChar(255)
  Country             String?   @db.VarChar(255)
  State               String?   @db.VarChar(255)
  City                String?   @db.VarChar(255)
  Zip                 String?   @db.VarChar(255)
  Address             String?   @db.Text
  isRemoteArea        Boolean?  @default(false)
  remoteAreaCompanies String?   @db.LongText
  createdAt           DateTime? @default(now()) @db.DateTime(0)
}

model DeliveryTime {
  id        Int       @id @default(autoincrement())
  name      String    @unique(map: "name") @db.VarChar(255)
  createdAt DateTime? @default(now()) @db.DateTime(0)
}

model Agency {
  id        Int      @id @default(autoincrement())
  code      String   @unique(map: "Agency_code_key") @db.VarChar(255)
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now())
}

model Office {
  id        Int       @id @default(autoincrement())
  code      String    @unique(map: "code") @db.VarChar(255)
  name      String    @db.VarChar(255)
  createdAt DateTime? @default(now()) @db.DateTime(0)
}

model InvoiceStatus {
  id        Int       @id @default(autoincrement())
  name      String    @unique(map: "name") @db.VarChar(255)
  createdAt DateTime? @default(now()) @db.DateTime(0)
}

model DeliveryStatus {
  id        Int       @id @default(autoincrement())
  name      String    @unique(map: "name") @db.VarChar(255)
  createdAt DateTime? @default(now()) @db.DateTime(0)
}

model ShippingMode {
  id        Int       @id @default(autoincrement())
  name      String    @unique(map: "name") @db.VarChar(255)
  createdAt DateTime? @default(now()) @db.DateTime(0)
}

model PackagingType {
  id        Int       @id @default(autoincrement())
  name      String    @unique(map: "name") @db.VarChar(255)
  createdAt DateTime? @default(now()) @db.DateTime(0)
}

model ServiceMode {
  id        Int       @id @default(autoincrement())
  name      String    @unique(map: "name") @db.VarChar(255)
  createdAt DateTime? @default(now()) @db.DateTime(0)
}

model Zone {
  id        Int     @id @default(autoincrement())
  code      String  @db.VarChar(255)
  country   String  @db.VarChar(255)
  zone      String  @db.VarChar(255)
  service   String  @db.VarChar(255)
  phoneCode String? @db.VarChar(255)
}

model ZoneUpload {
  id         Int       @id @default(autoincrement())
  service    String    @unique(map: "service") @db.VarChar(255)
  uploadedAt DateTime? @default(now()) @db.DateTime(0)
}

model RemoteArea {
  id         Int       @id @default(autoincrement())
  company    String    @db.VarChar(255)
  country    String    @db.VarChar(255)
  iataCode   String    @db.VarChar(255)
  low        String    @db.VarChar(255)
  high       String    @db.VarChar(255)
  city       String?   @db.VarChar(255)
  filename   String?   @db.VarChar(255)
  uploadedAt DateTime? @default(now()) @db.DateTime(0)
}

model Rate {
  id      Int    @id @default(autoincrement())
  weight  Float
  vendor  String @db.VarChar(255)
  service String @db.VarChar(255)
  zone    String @db.VarChar(255)
  price   Int
  docType String @db.VarChar(255)
}

model filename {
  id         Int       @id @default(autoincrement())
  filename   String    @db.VarChar(255)
  vendor     String    @db.VarChar(255)
  service    String    @db.VarChar(255)
  fileType   String    @db.VarChar(255)
  uploadedAt DateTime? @default(now()) @db.DateTime(0)

  @@unique([service, fileType], map: "unique_service_fileType")
}

model CustomerTransaction {
  id              Int       @id @default(autoincrement())
  customerId      Int
  type            String    @db.VarChar(50)
  amount          Decimal   @db.Decimal(15, 2)
  description     String    @db.Text
  reference       String?   @db.VarChar(255)
  invoice         String?   @db.VarChar(255)
  previousBalance Decimal   @db.Decimal(15, 2)
  newBalance      Decimal   @db.Decimal(15, 2)
  createdAt       DateTime? @default(now()) @db.DateTime(0)
  customer        Customers @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([createdAt], map: "idx_createdAt")
  @@index([customerId], map: "idx_customerId")
}

model VendorTransaction {
  id              Int       @id @default(autoincrement())
  vendorId        Int
  type            String    @db.VarChar(50)
  amount          Decimal   @db.Decimal(15, 2)
  description     String    @db.Text
  reference       String?   @db.VarChar(255)
  invoice         String?   @db.VarChar(255)
  previousBalance Decimal   @db.Decimal(15, 2)
  newBalance      Decimal   @db.Decimal(15, 2)
  createdAt       DateTime? @default(now()) @db.DateTime(0)
  vendor          Vendors   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([createdAt], map: "idx_createdAt")
  @@index([vendorId], map: "idx_vendorId")
}

model vendorservice {
  id      Int    @id @default(autoincrement())
  vendor  String @db.VarChar(255)
  service String @db.VarChar(255)
}

model Payment {
  id              Int       @id @default(autoincrement())
  transactionType String    @db.VarChar(50)
  category        String    @db.VarChar(255)
  date            DateTime  @db.DateTime(0)
  amount          Decimal   @db.Decimal(15, 2)
  fromPartyType   String    @db.VarChar(50)
  fromCustomerId  Int?
  fromCustomer    String    @db.VarChar(255)
  toPartyType     String    @db.VarChar(50)
  toVendorId      Int?
  toVendor        String    @db.VarChar(255)
  mode            String?   @db.VarChar(50)
  reference       String?   @db.VarChar(255)
  invoice         String?   @db.VarChar(255)
  description     String?   @db.Text
  createdAt       DateTime? @default(now()) @db.DateTime(0)
  updatedAt       DateTime? @default(now()) @updatedAt @db.DateTime(0)
}

model Invoice {
  id             Int          @id @default(autoincrement())
  invoiceNumber  String       @unique(map: "invoiceNumber") @db.VarChar(255)
  invoiceDate    DateTime     @db.DateTime(0)
  receiptNumber  String?      @db.VarChar(255)
  trackingNumber String?      @db.VarChar(255)
  destination    String       @db.VarChar(255)
  dayWeek        String?      @db.VarChar(255)
  weight         Float
  profile        String       @db.VarChar(255)
  fscCharges     Decimal?     @default(0.00) @db.Decimal(15, 2)
  lineItems      String       @db.LongText
  customerId     Int?
  vendorId       Int?
  shipmentId     Int?
  disclaimer     String?      @db.Text
  status         String?      @default("Unpaid") @db.VarChar(50)
  totalAmount    Decimal      @db.Decimal(15, 2)
  currency       String?      @default("USD") @db.VarChar(10)
  createdAt      DateTime?    @default(now()) @db.DateTime(0)
  updatedAt      DateTime?    @default(now()) @updatedAt @db.DateTime(0)
  discount       Decimal?     @default(0.00) @db.Decimal(15, 2)
  customer       Customers?   @relation(fields: [customerId], references: [id])
  vendor         Vendors?     @relation(fields: [vendorId], references: [id])
  shipment       Shipment?    @relation(fields: [shipmentId], references: [id])
  debitNotes     DebitNote[]
  creditNotes    CreditNote[]
}

model DebitNote {
  id              Int       @id @default(autoincrement())
  debitNoteNumber String    @unique(map: "debitNoteNumber") @db.VarChar(255)
  billId          Int?
  vendorId        Int?
  amount          Decimal   @db.Decimal(15, 2)
  date            DateTime  @db.DateTime(0)
  description     String?   @db.Text
  currency        String?   @default("USD") @db.VarChar(10)
  createdAt       DateTime? @default(now()) @db.DateTime(0)
  updatedAt       DateTime? @default(now()) @updatedAt @db.DateTime(0)
  bill            Invoice?  @relation(fields: [billId], references: [id])
  vendor          Vendors?  @relation(fields: [vendorId], references: [id])
}

model CreditNote {
  id               Int        @id @default(autoincrement())
  creditNoteNumber String     @unique(map: "CreditNote_creditNoteNumber_key") @db.VarChar(255)
  invoiceId        Int
  customerId       Int
  amount           Float
  date             DateTime   @db.DateTime(0)
  description      String     @db.VarChar(255)
  currency         String     @db.VarChar(255)
  createdAt        DateTime   @default(now()) @db.DateTime(0)
  updatedAt        DateTime   @default(now()) @updatedAt @db.DateTime(0)
  invoice          Invoice?   @relation(fields: [invoiceId], references: [id])
  customer         Customers? @relation(fields: [customerId], references: [id])
}

model ChartOfAccount {
  id           Int                @id @default(autoincrement())
  code         String             @unique(map: "ChartOfAccount_code_key") @db.VarChar(255)
  accountName  String             @db.VarChar(255)
  category     String             @db.VarChar(255)
  type         String             @db.VarChar(255)
  debitRule    String             @db.VarChar(255)
  creditRule   String             @db.VarChar(255)
  description  String             @db.VarChar(255)
  isActive     Boolean
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @default(now()) @updatedAt
  journalLines JournalEntryLine[]
}

model JournalEntry {
  id          Int                @id @default(autoincrement())
  entryNumber String             @unique(map: "entryNumber") @db.VarChar(255)
  date        DateTime           @db.DateTime(0)
  description String             @db.Text
  reference   String?            @db.VarChar(255)
  totalDebit  Decimal            @db.Decimal(15, 2)
  totalCredit Decimal            @db.Decimal(15, 2)
  isPosted    Boolean?           @default(false)
  postedAt    DateTime?          @db.DateTime(0)
  createdAt   DateTime?          @default(now()) @db.DateTime(0)
  updatedAt   DateTime?          @default(now()) @updatedAt @db.DateTime(0)
  lines       JournalEntryLine[]
}

model JournalEntryLine {
  id             Int            @id @default(autoincrement())
  journalEntryId Int
  accountId      Int
  debitAmount    Decimal?       @default(0.00) @db.Decimal(15, 2)
  creditAmount   Decimal?       @default(0.00) @db.Decimal(15, 2)
  description    String?        @db.Text
  reference      String?        @db.VarChar(255)
  createdAt      DateTime?      @default(now()) @db.DateTime(0)
  journalEntry   JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account        ChartOfAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model FixedCharge {
  id          Int       @id @default(autoincrement())
  weight      Float
  fixedCharge Decimal   @db.Decimal(15, 2)
  createdAt   DateTime? @default(now()) @db.DateTime(0)
}

/// Key-value settings (expect primary key on `key` in MySQL).
model AppSetting {
  key   String @id @db.VarChar(255)
  value String @db.VarChar(255)
}
